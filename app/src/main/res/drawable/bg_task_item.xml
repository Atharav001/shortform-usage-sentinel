    </item>
    <!-- Default state -->
    <item>
        <shape>
            <solid android:color="@color/gray_800_30" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="@color/gray_700" />
        </shape>
    </item>
</selector>