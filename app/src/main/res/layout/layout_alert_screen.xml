<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/obsidian_black"
    android:fitsSystemWindows="true">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomActions"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Compact Alert Header (Blended Gradient) -->
            <LinearLayout
                android:id="@+id/headerContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_alert_header_instagram"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_icon_circle">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="⏰"
                        android:textSize="24sp" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Take a Break"
                        android:textColor="@color/white"
                        android:textSize="17sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/tvStats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="45 reels scrolled today"
                        android:textColor="@color/white"
                        android:alpha="0.6"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_limit_card"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp">

                    <TextView
                        android:id="@+id/tvLimit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="50"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIMIT"
                        android:textColor="@color/white"
                        android:alpha="0.5"
                        android:textSize="8sp"
                        android:fontFamily="sans-serif-black" />
                </LinearLayout>
            </LinearLayout>

            <!-- Tab Switcher (Glassmorphic) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_tab_switcher"
                android:padding="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tabHabits"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_selected"
                    android:gravity="center"
                    android:text="Habits"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-bold"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tabTasks"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Tasks"
                    android:textColor="@color/gray_500"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Content Area (Dual Section View) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="24dp">

                <!-- Habits Section -->
                <LinearLayout
                    android:id="@+id/habitsSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/tvHabitsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="1/3 completed"
                        android:textColor="@color/gray_400"
                        android:textSize="13sp" />

                    <ProgressBar
                        android:id="@+id/pbHabits"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginBottom="20dp"
                        android:progressDrawable="@drawable/bg_habit_progress"
                        android:background="@drawable/bg_progress_track" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal">
                        <EditText
                            android:id="@+id/etHabit"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_edittext_alert"
                            android:hint="Add new habit..."
                            android:paddingHorizontal="16dp"
                            android:textColor="@color/white"
                            android:textColorHint="@color/gray_500"
                            android:textSize="14sp"
                            android:inputType="text"
                            android:maxLines="1" />
                        <ImageButton
                            android:id="@+id/btnAddHabit"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_button_add_habit"
                            android:src="@drawable/ic_plus"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvHabits"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_alert_task" />
                </LinearLayout>

                <!-- Tasks Section -->
                <LinearLayout
                    android:id="@+id/tasksSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvTasksCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="0/2 completed"
                        android:textColor="@color/gray_400"
                        android:textSize="13sp" />

                    <ProgressBar
                        android:id="@+id/pbTasks"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="6dp"
                        android:layout_marginBottom="20dp"
                        android:progressDrawable="@drawable/bg_task_progress"
                        android:background="@drawable/bg_progress_track" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal">
                        <EditText
                            android:id="@+id/etTask"
                            android:layout_width="0dp"
                            android:layout_height="52dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_edittext_alert"
                            android:hint="Add new task..."
                            android:paddingHorizontal="16dp"
                            android:textColor="@color/white"
                            android:textColorHint="@color/gray_500"
                            android:textSize="14sp"
                            android:inputType="text"
                            android:maxLines="1" />
                        <ImageButton
                            android:id="@+id/btnAddTask"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:layout_marginStart="12dp"
                            android:background="@drawable/bg_button_add_task"
                            android:src="@drawable/ic_plus"
                            app:tint="@color/white" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvTasks"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_alert_task" />
                </LinearLayout>

            </FrameLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_alert_footer_gradient"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnQuit"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button_quit_gradient"
            app:backgroundTint="@null"
            android:text="TAKE A BREAK &amp; EXIT"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            app:cornerRadius="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnContinue"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_button_continue_outline"
            app:backgroundTint="@null"
            android:text="Dismiss &amp; Continue Watching"
            android:textColor="@color/gray_500"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            app:cornerRadius="18dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
